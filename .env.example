NODE_ENV=local
SERVER_PORT=7007

# Database config local
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=
POSTGRES_DB=your-postgres-db

# JWT
SECRET_KEY=replace-with-a-local-secret
REFRESH_SECRET_KEY=replace-with-a-local-refresh-secret

# Email
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-smtp-user
MAIL_PASSWORD=
MAIL_FROM_EMAIL=notifications@example.com
CLIENT_URL=http://localhost:3000
SEND_MAIL=false

# Redis
REDISHOST=localhost
REDISPORT=6379
REDIS_PASSWORD=

SEED_PASSWORD_PLAIN=replace-with-a-local-seed-password
MAIL_HEALTH_KEY=replace-with-a-local-mail-health-key
ALLOWED_ORIGINS=http://localhost:3000

# Remote database URLs should be supplied by your deployment platform and
# should never be committed to this repository.
# DATABASE_PUBLIC_URL=
# DATABASE_URL=
