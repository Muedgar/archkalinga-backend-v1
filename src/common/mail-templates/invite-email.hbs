<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>You've been invited to ArchKalinga</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f0f4f8;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #1e293b;
      }

      p {
        color: #334155;
      }

      .container {
        max-width: 600px;
        margin: 40px auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
        border: 1px solid #cbd5e1;
      }

      .header {
        background-color: #1e3a5f;
        padding: 28px 24px;
        text-align: center;
      }

      .header h1 {
        margin: 0;
        color: #ffffff;
        font-size: 22px;
        font-weight: 700;
        letter-spacing: 0.5px;
      }

      .header p {
        margin: 6px 0 0;
        color: #93c5fd;
        font-size: 13px;
      }

      .content {
        padding: 32px;
      }

      .content p {
        font-size: 15px;
        line-height: 1.7;
        margin: 0 0 18px;
      }

      .notice {
        background-color: #eff6ff;
        border-left: 4px solid #2563eb;
        padding: 14px 16px;
        border-radius: 4px;
        margin-bottom: 24px;
        font-size: 14px;
        color: #1e40af;
      }

      .button {
        display: inline-block;
        background-color: #2563eb;
        color: #ffffff !important;
        padding: 14px 28px;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
        font-size: 15px;
        margin-top: 8px;
      }

      .divider {
        border: none;
        border-top: 1px solid #e2e8f0;
        margin: 28px 0;
      }

      .footer {
        padding: 20px 24px;
        text-align: center;
        font-size: 13px;
        background-color: #f8fafc;
        color: #64748b;
        border-top: 1px solid #e2e8f0;
      }

      @media (max-width: 600px) {
        .content,
        .header,
        .footer {
          padding: 16px;
        }

        .button {
          display: block;
          width: 100%;
          text-align: center;
          box-sizing: border-box;
        }
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='header'>
        <h1>ArchKalinga</h1>
        <p>Project &amp; Architecture Management</p>
      </div>
      <div class='content'>
        <p>Hi {{data.firstName}},</p>
        <p>You've been invited to join
          <strong>ArchKalinga</strong>
          — a platform for managing projects, change requests, tasks, and team
          workflows with clarity and precision.</p>
        <p>Click the button below to set your password and activate your
          account. This invitation link expires in
          <strong>24 hours</strong>.</p>

        <a
          href='{{data.clientUrl}}/accept-invite?token={{data.inviteToken}}'
          target='_blank'
          class='button'
        >
          Accept Invitation &amp; Set Password →
        </a>

        <div class='notice' style='margin-top: 32px;'>
          This link is personal — please do not share it. If you weren't
          expecting this invitation, you can safely ignore this email.
        </div>

        <hr class='divider' />
        <p style='font-size: 13px; color: #94a3b8; margin: 0;'>This invitation
          was sent by your organization admin on ArchKalinga.</p>
      </div>
      <div class='footer'>
        ©
        {{data.year}}
        ArchKalinga. All rights reserved.
      </div>
    </div>
  </body>
</html>