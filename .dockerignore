# Dependencies (reinstalled inside Docker)
node_modules

# Compiled output (rebuilt inside Docker)
dist

# Environment files (injected by Railway at runtime)
.env
.env.*

# Git
.git
.gitignore

# Docs & local tooling
*.md
docs/
*.docx

# Tests
test/
**/*.spec.ts
**/*.e2e-spec.ts

# npm local config should not leak host-specific install settings into Docker
.npmrc

# Editor / OS
.DS_Store
.vscode/
*.log
